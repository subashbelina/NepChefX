{
  "expo": {
    "name": "NepChefX",
    "slug": "NepChefX",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/NepChefXlogo.png",
    "scheme": "nepchefx",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF3E0",
        "foregroundImage": "./assets/images/NepChefXlogo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/NepChefXlogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/NepChefXlogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFF3E0",
          "dark": {
            "backgroundColor": "#1C1B1F"
          }
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
