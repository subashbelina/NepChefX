# Copy to `.env` and fill in. Restart Expo after changes.
# https://huggingface.co/settings/tokens

# Hugging Face (used first if set). Token needs "Inference Providers" permission.
EXPO_PUBLIC_HF_TOKEN=
# Optional: preferred model (tried first). If unsupported, the app tries other models automatically.
# Enable providers: https://huggingface.co/settings/inference-providers
# EXPO_PUBLIC_HF_MODEL=Qwen/Qwen2.5-7B-Instruct:cheapest

# OpenAI (used only if HF token is not set)
# EXPO_PUBLIC_OPENAI_API_KEY=

# Supabase (ONLY needed if you integrate Supabase in the app)
# Safe to expose in Expo (client-side) because it's the public anon key.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (DO NOT put these in Expo env / do not prefix with EXPO_PUBLIC_)
# Use only in backend scripts/servers, never in a shipped mobile app.
# SUPABASE_SERVICE_ROLE_KEY=
# Example format (from Supabase Project Settings → Database):
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres
